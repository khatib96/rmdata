    "notes_ar": [
      "أذكار الصباح تظهر من 07:00 حتى 11:00.",
      "أذكار المساء تظهر من 16:00 حتى 18:00.",
      "أدعية رمضان تظهر فقط إذا كان الشهر الهجري هو رمضان.",
      "التحفيز يظهر بشكل عشوائي في الأوقات الأخرى.",
      "العام يظهر في أي وقت كفاصل عشوائي.",
      "رسائل الجمعة مخصصة ليوم الجمعة ويمكن حقنها طوال اليوم."
    ]
  },
  "selection_engine": {
    "resolver_strategy": "highest_priority_active_category_then_weighted_random",
    "category_priority_order": [
      "ramadan",
      "friday",
      "morning",
      "evening",
      "motivation",
      "general",
      "quick"
    ],
    "fallback_categories": [
      "motivation",
      "general",
      "quick"
    ],
    "deduplication": {
      "prevent_same_message_consecutively": true,
      "prevent_same_category_consecutively": false,
      "recommended_cooldown_minutes_for_same_message": 180
    },
    "randomization": {
      "strategy": "weighted_random",
      "default_weight": 1
    }
  },
  "api_contract": {
    "resource_name": "messages",
    "base_path": "/api/v1/messages",
    "supported_filters": [
      "category",
      "active_at",
      "weekday",
      "hijri_month",
      "channel",
      "enabled",
      "limit",
      "random"
    ],
    "recommended_endpoints": [
      {
        "method": "GET",
        "path": "/api/v1/messages",
        "purpose_ar": "إرجاع الرسائل مع دعم الفلترة حسب التصنيف أو الحالة."
      },
      {
        "method": "GET",
        "path": "/api/v1/messages/resolve?active_at=2026-03-18T08:30:00+03:00",
        "purpose_ar": "اختيار أفضل رسالة مناسبة حسب الوقت والسياق."
      },
      {
        "method": "GET",
        "path": "/api/v1/messages/random?category=general&limit=5",
        "purpose_ar": "إرجاع رسائل عشوائية من تصنيف محدد."
      }
    ],
    "response_core_fields": [
      "id",
      "code",
      "category",
      "text_ar",
      "priority",
      "enabled",
      "rule_ids"
    ]
  },
  "rules": [
    {
      "id": "rule_morning_time",
      "type": "time_window",
      "description_ar": "تفعيل الرسائل الصباحية يومياً بين 07:00 و 11:00 حسب توقيت النظام.",
      "config": {
        "timezone": "Asia/Qatar",
        "start_time": "07:00",
        "end_time": "11:00",
        "inclusive_start": true,
        "exclusive_end": false
      }
    },
    {
      "id": "rule_evening_time",
      "type": "time_window",
      "description_ar": "تفعيل الرسائل المسائية يومياً بين 16:00 و 18:00 حسب توقيت النظام.",
      "config": {
        "timezone": "Asia/Qatar",
        "start_time": "16:00",
        "end_time": "18:00",
        "inclusive_start": true,
        "exclusive_end": false
      }
    },
    {
      "id": "rule_ramadan_hijri_month",
      "type": "hijri_calendar_month",
      "description_ar": "تفعيل الرسائل الرمضانية فقط عند توافق التاريخ الهجري مع شهر رمضان.",
      "config": {
        "calendar": "hijri",
        "month_number": 9,
        "month_name_ar": "رمضان",
        "month_name_en": "Ramadan"
      }
    },
    {
      "id": "rule_friday_anytime",
      "type": "weekday",
      "description_ar": "تفعيل رسائل الجمعة طوال يوم الجمعة.",
      "config": {
        "weekday_iso": 5,
        "weekday_name_ar": "الجمعة",
        "weekday_name_en": "Friday",
        "active_all_day": true
      }
    },
    {
      "id": "rule_other_times",
      "type": "composite_fallback",
      "description_ar": "تستخدم العبارات التحفيزية في الأوقات الأخرى خارج الصباح والمساء ورمضان، ويمكن جعلها fallback بعد الرسائل السياقية الأعلى أولوية.",
      "config": {
        "exclude_rule_ids": [
          "rule_morning_time",
          "rule_evening_time",
          "rule_ramadan_hijri_month"
        ],
        "selection_policy": "weighted_random"
      }
    },
    {
      "id": "rule_anytime",
      "type": "anytime",
      "description_ar": "رسائل عامة متاحة في أي وقت كفواصل عشوائية.",
      "config": {
        "selection_policy": "weighted_random"
      }
    },
    {
      "id": "rule_anytime_short",
      "type": "anytime",
      "description_ar": "إشعارات قصيرة متاحة في أي وقت لاستخدامها كتذكيرات سريعة.",
      "config": {
        "selection_policy": "weighted_random",
        "max_length_hint": "short"
      }
    }
  ],
