# اختياري: عند فتح الواجهة من الجوال وإذا كانت الطلبات لا تصل، ضع IP جهازك والمنفذ 3001
# استبدل 192.168.100.177 بعنوان IP للكمبيوتر الذي يشغّل خادم API
# VITE_API_BASE=http://192.168.100.177:3001

# لـ npm run dev:api / خادم server/dev-api-server.js — انسخ القيم من api-gateway-php/.env أو صدّرها في الطرفية:
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=your_database
# DB_USER=your_user
# DB_PASSWORD=your_password
# RMDATA_STORAGE_ROOT=C:/path/to/RMDATA_SYSTEM/api-gateway-php/storage
